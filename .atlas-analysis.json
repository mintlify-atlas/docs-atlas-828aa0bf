  "keyFeatures": [
    "TLS 1.0, 1.1, 1.2, and 1.3 support",
    "Post-quantum cryptography (ML-KEM and ML-DSA)",
    "FIPS mode support via AWS-LC or OpenSSL",
    "Multiple libcrypto backends (AWS-LC, OpenSSL, BoringSSL, LibreSSL)",
    "Security policies for easy cipher suite management",
    "Non-blocking and full-duplex I/O support",
    "Session resumption and pre-shared keys",
    "Certificate revocation via OCSP stapling and CRLs",
    "Timing blinding to prevent side-channel attacks",
    "Rust language bindings",
    "Memory protection and erase-on-read",
    "Minimal attack surface by design"
  ],
